# Chart Analysis
CANDLE_PERIOD=D
LOOKBACK_DAYS=7

# Bot Settings
UPDATE_INTERVAL_SECONDS=300
ENABLE_AUTO_TRADING=true

# Logging
LOG_LEVEL=INFO
