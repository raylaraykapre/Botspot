# Bybit API Configuration
BYBIT_API_KEY_DEMO=
BYBIT_API_SECRET_DEMO=
BYBIT_API_KEY_REAL=
BYBIT_API_SECRET_REAL=

# Trading Mode: 'demo' or 'real'
TRADING_MODE=demo

# Currency Settings
BASE_CURRENCY=PHP
FIAT_CURRENCY=USDT

# Trading Settings
BUY_AMOUNT_PHP=5000
PROFIT_TARGET_PERCENT=7
